generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  SAP
  UTILITY
  TRAVEL
}

enum ReviewStatus {
  PENDING
  FLAGGED
  APPROVED
  REJECTED
  LOCKED
}

enum ScopeCategory {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model IngestionBatch {
  id           String     @id @default(cuid())
  sourceType   SourceType
  filename     String?
  uploadedById String
  uploadedAt   DateTime   @default(now())

  records EmissionRecord[]
}

model EmissionRecord {
  id           String        @id @default(cuid())
  sourceType   SourceType
  scope        ScopeCategory
  activityType String

  rawPayload        Json
  normalizedPayload Json

  normalizedUnit  String
  normalizedValue Float

  reviewStatus ReviewStatus @default(PENDING)

  validationIssues ValidationIssue[]
  reviewActions    ReviewAction[]
  auditLogs        AuditLog[]

  batchId String
  batch   IngestionBatch @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())
}

model ValidationIssue {
  id       String @id @default(cuid())
  message  String
  severity String

  recordId String
  record   EmissionRecord @relation(fields: [recordId], references: [id])
}

model ReviewAction {
  id          String  @id @default(cuid())
  action      String
  comment     String?
  performedBy String

  recordId String
  record   EmissionRecord @relation(fields: [recordId], references: [id])

  createdAt DateTime @default(now())
}

model AuditLog {
  id        String  @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  changedBy String

  recordId String
  record   EmissionRecord @relation(fields: [recordId], references: [id])

  createdAt DateTime @default(now())
}
